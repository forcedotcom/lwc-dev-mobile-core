{
    "extends": "@salesforce/dev-config/tsconfig-strict-esm",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "pretty": true,
        "declarationMap": true,
        "removeComments": true,
        "skipLibCheck": true
    },
    "include": ["./src/**/*.ts"],
    "ts-node": {
        "esm": true,
        "compilerOptions": {
            "types": ["mocha", "node"]
        }
    }
}
